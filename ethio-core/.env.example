# Ethio-Core Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_USER=ethio
POSTGRES_PASSWORD=ethio_secret_change_me
POSTGRES_DB=ethio_core
DATABASE_URL=postgresql://ethio:ethio_secret_change_me@localhost:5432/ethio_core

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=redis_secret_change_me

# =============================================================================
# Security & Authentication
# =============================================================================
# JWT secret key (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_key_change_in_production_min_32_chars

# Encryption key for sensitive data (must be 32 bytes)
ENCRYPTION_KEY=your_encryption_key_32_bytes_here

# =============================================================================
# OAuth2 / SSO Configuration
# =============================================================================
OAUTH2_CLIENT_ID=ethio_client
OAUTH2_CLIENT_SECRET=ethio_client_secret_change_me
OAUTH2_REDIRECT_URI=http://localhost:3000/callback

# =============================================================================
# Service URLs (Production)
# =============================================================================
API_URL=https://api.ethio-core.com
SSO_URL=https://sso.ethio-core.com
FRONTEND_URL=https://ethio-core.com

# =============================================================================
# External Service Integration (Mock/Production)
# =============================================================================
# Fayda API (Ethiopia National ID)
FAYDA_API_URL=https://api.fayda.et
FAYDA_API_KEY=your_fayda_api_key

# OCR Service
OCR_SERVICE_URL=http://localhost:8010
OCR_API_KEY=your_ocr_api_key

# =============================================================================
# Logging & Monitoring
# =============================================================================
LOG_LEVEL=DEBUG
ENVIRONMENT=development

# Sentry (Error Tracking)
SENTRY_DSN=

# =============================================================================
# Container Registry (Production)
# =============================================================================
REGISTRY=your-registry.azurecr.io
VERSION=latest

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_BIOMETRIC_AUTH=true
ENABLE_OFFLINE_TRANSACTIONS=true
ENABLE_DYNAMIC_CVV=true
