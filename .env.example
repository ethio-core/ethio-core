# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ethio_core
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Event Store
EVENT_STORE_SCHEMA=public
EVENT_STORE_BATCH_SIZE=1000

# JWT
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth2
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_REDIRECT_URI=http://localhost:3000/callback

# Fayda API
FAYDA_API_URL=https://api.fayda.gov.et/v1
FAYDA_API_KEY=
FAYDA_API_SECRET=

# Kifiya Integration
KIFIYA_API_URL=https://api.kifiya.com/v1
KIFIYA_API_KEY=

# AI Models
FACE_RECOGNITION_MODEL_PATH=/models/facenet.h5
LIVENESS_THRESHOLD=0.85
RISK_THRESHOLD=0.7

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Metrics
PROMETHEUS_PORT=9090

# Offline Payments
OFFLINE_VOUCHER_EXPIRY_SECONDS=300
MAX_OFFLINE_SEQUENCE_GAP=5

# Docker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ethio_core

# Kubernetes
KUBERNETES_NAMESPACE=ethio-core
